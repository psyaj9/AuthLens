# AuthLens backend environment template.
# Copy to .env at the repo root, or to server/.env when running uvicorn from server/.
# Never commit real API keys, tokens, patient data, or local-only secret values.

# Required backend secrets.
GROQ_API_KEY=
GOOGLE_API_KEY=
PINECONE_API_KEY=

# Required backend service configuration.
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=local

# Optional backend configuration.
GROQ_MODEL=llama-3.1-8b-instant
INTERNAL_API_TOKEN=
MAX_UPLOAD_MB=10
MAX_UPLOAD_FILES=5

# Frontend env belongs in frontend/.env.local or frontend/.env.example:
# BACKEND_API_URL=http://localhost:8000
# INTERNAL_API_TOKEN=
