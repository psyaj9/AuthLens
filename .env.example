# AuthLens backend environment template.
# Copy to server/.env for local backend runs from server/.
# Never commit real API keys, tokens, patient data, or local-only secret values.

# Required backend secrets.
GROQ_API_KEY=
GOOGLE_API_KEY=
PINECONE_API_KEY=

# Required backend service configuration.
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=
ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=local
DATABASE_URL=sqlite:///server/authlens.db

# Optional backend configuration.
GROQ_MODEL=llama-3.1-8b-instant
PRIORAUTH_ANALYSIS_MODE=deterministic
PRIORAUTH_LLM_MODEL=
PRIORAUTH_LLM_MAX_TOKENS=2000
JWT_SECRET=
INTERNAL_API_TOKEN=
PASSWORD_RESET_DELIVERY_MODE=
MAX_UPLOAD_MB=10
MAX_UPLOAD_FILES=5

# Client env belongs in client/.env.local. See client/.env.example.
# BACKEND_API_URL=http://localhost:8000
# INTERNAL_API_TOKEN=
